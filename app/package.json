{
  "name": "brandos",
  "version": "0.1.0",
  "private": true,
  "description": "BrandOS core engine — multi-workspace evidence and brand archive platform.",
  "type": "commonjs",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "scan": "tsx src/cli/scan.ts",
    "verify": "tsx src/cli/verify.ts",
    "list-workspaces": "tsx src/cli/list-workspaces.ts",
    "analyze": "tsx src/cli/analyze.ts",
    "seed-cases": "tsx src/cli/seed-cases.ts",
    "generate-vault": "tsx src/cli/generate-vault.ts",
    "import-zip": "tsx src/cli/import-zip.ts",
    "list-plugins": "tsx src/cli/list-plugins.ts",
    "list-imports": "tsx src/cli/list-imports.ts",
    "validate-golden-dataset": "tsx src/cli/validate-golden-dataset.ts",
    "generate-report": "tsx src/cli/generate-report.ts",
    "api": "tsx src/api/server.ts"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "ajv": "^8.17.1",
    "cors": "^2.8.6",
    "exifr": "^7.1.3",
    "express": "^5.2.1",
    "pdf-parse": "^1.1.1",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "@types/sql.js": "^1.4.11",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
