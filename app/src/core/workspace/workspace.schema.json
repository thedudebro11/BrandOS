{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://brandos/workspace.schema.json",
  "title": "BrandOS Workspace Config",
  "type": "object",
  "required": ["id", "name", "type", "status", "modules"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "created": { "type": "string" },
    "primaryUseCase": { "type": "string" },
    "modules": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "paths": {
      "type": "object",
      "properties": {
        "obsidianVault": { "type": "string" },
        "exports": { "type": "string" },
        "reviewQueue": { "type": "string" }
      },
      "additionalProperties": false
    },
    "importantMarks": {
      "type": "object",
      "properties": {
        "primaryMark": { "type": ["string", "null"] },
        "relatedOrConflictingMarks": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "evidenceTypes": { "type": "array", "items": { "type": "string" } },
    "caseTypes": { "type": "array", "items": { "type": "string" } }
  }
}
