{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "name", "version", "type", "description", "capabilities", "activatesOn", "engineCompatibility"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "type": { "type": "string", "enum": ["Importer", "Classifier", "ReportTemplate", "VaultTemplate"] },
    "description": { "type": "string", "minLength": 1 },
    "capabilities": { "type": "array", "items": { "type": "string" } },
    "activatesOn": { "type": "array", "items": { "type": "string" } },
    "engineCompatibility": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pluginId", "minVersion"],
        "additionalProperties": false,
        "properties": {
          "pluginId": { "type": "string" },
          "minVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
        }
      }
    }
  }
}
